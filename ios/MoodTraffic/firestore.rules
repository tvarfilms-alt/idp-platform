rules_version = '2';

// Security model for the couples app:
// - Everyone must be signed in (anonymous auth is fine).
// - You can create/update your own member document inside a pair.
// - You can read everything in a pair, and write ratings, only once you are a
//   member of that pair. This keeps a stranger who guesses the pair code from
//   reading or writing data unless they have explicitly joined.
service cloud.firestore {
  match /databases/{database}/documents {

    match /pairs/{pairId} {

      function isMember() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/pairs/$(pairId)/members/$(request.auth.uid));
      }

      // A signed-in user may create/update only their own member doc.
      match /members/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Ratings: readable by members; each user may only write their own rows
      // (document id is "<date>_<uid>" and the uid field must match).
      match /ratings/{ratingId} {
        allow read: if isMember();
        allow write: if request.auth != null
          && request.resource.data.uid == request.auth.uid;
      }
    }
  }
}

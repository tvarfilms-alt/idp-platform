# IDP Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git!

# ===== Supabase (cloud DB) =====
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJI...

# ===== PostgreSQL (local Docker, optional) =====
PG_DB=idp
PG_USER=idp_admin
PG_PASSWORD=CHANGE_ME_STRONG_PASSWORD
PG_PORT=5432
PG_HOST=localhost

# ===== Finance Marker API =====
FM_API_TOKEN=your_fm_api_token

# ===== Cbonds API =====
CBONDS_API_KEY=your_cbonds_api_key_here

# ===== Telegram Alerts =====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ===== Dashboard =====
DASHBOARD_PORT=8080

# ===== General =====
TIMEZONE=Europe/Moscow
LOG_LEVEL=INFO

rules_version = '2';

// Скопируй это в Firebase Console -> Firestore Database -> Rules -> Publish.
//
// Модель безопасности для приложения «для двоих»:
//  - Нужна авторизация (анонимная подходит).
//  - Стать участником пары можно, создав свой документ в members/{uid}.
//  - Читать данные пары и писать оценки/подписки могут только её участники.
//  - Писать можно только свои строки (uid должен совпадать с авторизацией).
service cloud.firestore {
  match /databases/{database}/documents {
    match /pairs/{pairId} {

      function isMember() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/pairs/$(pairId)/members/$(request.auth.uid));
      }

      // Свой member-документ может создавать/менять только сам пользователь.
      match /members/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Оценки: читают участники; писать можно только свои (id = "<дата>_<uid>").
      match /ratings/{ratingId} {
        allow read: if isMember();
        allow write: if request.auth != null
          && request.resource.data.uid == request.auth.uid;
      }

      // Подписки на push: пользователь управляет только своей.
      match /pushSubs/{uid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
